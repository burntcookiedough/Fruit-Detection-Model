# ==============================================================================
# Python & Virtual Environments
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
dist/
build/
*.egg-info/
*.egg

# ==============================================================================
# Datasets (Large files and directories generated during dataset prep)
# ==============================================================================
# Raw downloaded source datasets
raw_datasets/

# All processed dataset directories (balanced, augmented, etc.)
dataset/
dataset_*/
webcam_holdout/
synthetic_webcam_holdout/
_staging_*/

# YOLO label cache files (generated dynamically during training)
*.cache

# Compressed files & archives
*.zip
*.tar
*.gz
*.rar
*.7z

# ==============================================================================
# Model Weights & Exports
# ==============================================================================
# Ignore raw pretrained models in the repository root directory
/*.pt

# Runtime exports & serialized models (ONNX, TensorRT, TFLite, etc.)
*.onnx
*.engine
*.tflite
*.pb
*.torchscript
*.mlmodel
*_openvino_model/

# NOTE: Our final, trained weights located under the models/ directory
# are tracked as deliverables. If using Git LFS, track models/*.pt.

# ==============================================================================
# Training Runs, Outputs & Temporary Files
# ==============================================================================
runs/
output/
export/
inference/
tmp/
*.log
*.tmp

# ==============================================================================
# YOLO / Ultralytics Local Configurations
# ==============================================================================
Ultralytics/
.ultralytics/

# ==============================================================================
# Jupyter Notebook Checkpoints
# ==============================================================================
.ipynb_checkpoints/

# ==============================================================================
# IDEs & Code Editors
# ==============================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.settings/

# ==============================================================================
# Environment Variables & API Credentials
# ==============================================================================
.env
.env.*
secrets.yaml
kaggle.json

# ==============================================================================
# System Files
# ==============================================================================
