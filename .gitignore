# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# ============================================================
# Virtual Environment
# ============================================================
venv/
.venv/
env/
ENV/

# ============================================================
# Datasets  (large — regenerate via download/prepare/balance scripts)
# ============================================================
# Raw downloaded files (~8 GB)
raw_datasets/

# Intermediate merged dataset (pre-balancing, ~40k images)
dataset_v3_raw/

# Balanced final dataset (can be rebuilt from raw)
dataset/
dataset_v2/
dataset_v3/
dataset_v4/

# Legacy staging dirs
_staging_v2/
_staging_v3/

# Colab/Kaggle upload zip
dataset_v3_colab.zip
*.zip

# YOLO label cache files (auto-generated during training)
*.cache

# ============================================================
# Model Weights
# ============================================================
# Base pretrained weights downloaded from Ultralytics (not our work)
yolov8n.pt
yolov8s.pt
yolov8m.pt
yolov8l.pt
yolov8x.pt

# TensorRT / ONNX exports (large runtime artifacts)
*.engine
*.onnx
*.tflite
*.torchscript

# Our trained weights in models/ ARE tracked — they are the deliverable
# If they exceed 100 MB, switch to Git LFS:
#   git lfs track "models/*.pt"
# models/*.pt   <-- uncomment to ignore if using LFS

# ============================================================
# Training Runs & Outputs  (large, auto-generated by YOLO)
# ============================================================
runs/
output/

# ============================================================
# Jupyter Notebooks — checkpoints only, keep .ipynb files
# ============================================================
.ipynb_checkpoints/
# NOTE: *.ipynb files ARE tracked (Colab training notebook)

# ============================================================
# OS Files
# ============================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

